    print("☕ 程式已載入。10秒倒數準備，請切換至遊戲視窗...")
    for i in range(3, 0, -1):
        print(f"⏳ 倒數 {i} 秒...", end='\r')
        time.sleep(1)
    print("\n🚀 啟動！『多開並行架構』已上膛。由執行緒池掌控大局。")

    # 1. 啟動 Vision Provider (獨立執行緒)
    vision_thread = threading.Thread(target=global_vision_provider, daemon=True)
    vision_thread.start()
    
    # 等待第一幀畫面進來
    while LATEST_FRAME is None:
        time.sleep(0.1)

    # 2. 實例化所有大腦
    games = [MinesweeperGame(i+1, x, y) for i, (x, y) in enumerate(GAME_INSTANCES)]

    # 3. 將大腦丟入 ThreadPool 執行
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(games)) as executor:
        futures = [executor.submit(brain_worker, game) for game in games]
        
        # 主執行緒保持存活，監聽崩潰狀態
        try:
            for future in concurrent.futures.as_completed(futures):
                future.result() 
        except KeyboardInterrupt:
            print("\n🛑 程式手動終止。")
            os._exit(0)
