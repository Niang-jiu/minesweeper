def global_vision_provider():
    """🌍 全域視野提供者：以極高效能不斷刷新全螢幕 BGR"""
    global LATEST_FRAME
    sct = mss.mss()
    monitor_full = sct.monitors[1]
    
    while True:
        img = sct.grab(monitor_full)
        bgr = np.array(img)[:, :, :3]
        with FRAME_LOCK:
            LATEST_FRAME = bgr
        time.sleep(0.05) # 約 20 FPS，足夠極速辨識又不會燒 CPU

def brain_worker(game_instance):
    """🧠 獨立大腦執行緒：不斷向 Vision 索取畫面並推演"""
    
    # ✨ 核心修復：使用 with 語句在「目前這個專屬執行緒」內建立 mss，
    # 這樣 Windows 的 GDI 控制碼就會完美綁定在這條執行緒上，絕不報錯！
    with mss.mss() as sct:
        game_instance.local_sct = sct  # 把相機掛載到實例上
        
        while True:
            check_kill_switch()
            frame = None
            with FRAME_LOCK:
                if LATEST_FRAME is not None:
                    frame = LATEST_FRAME # 取得參照
                    
            if frame is not None:
                game_instance.process_tick(frame)
                
            time.sleep(0.05) # 控制大腦運算頻率

