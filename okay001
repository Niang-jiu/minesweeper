            if target:
                if target in RISK_ZONES and not risk_zone_cleared:
                    print(f"⚠️ 盲猜目標 {target} 位於結算高風險區，冷靜 5 秒並準備重新判斷...")
                    time.sleep(0.2)
                    risk_zone_cleared = True
                    continue

                set_flag_mode(False)
                click_and_watch(target[0], target[1], '?')
                risk_zone_cleared = False
            continue
            
    time.sleep(0.05)
