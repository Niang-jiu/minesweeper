                if network_failed:
                    print("   ⏳ 復原完畢，退回主迴圈等待...")
                    time.sleep(1.0)
            
            risk_zone_cleared = False
            if hit_win: continue 
            if not network_failed: print("⚠️ 窮舉結束皆未過關(可能是辨識落差)，準備退回盲猜...")
            continue

        else:
