            network_failed = False
            currently_guessed_flags = set() 
            
            for i, combo in enumerate(valid_configs):
                target_flags = set(combo)
                flags_to_pull = currently_guessed_flags - target_flags
                flags_to_plant = target_flags - currently_guessed_flags
                
                print(f"   👉 測試第 {i+1}/{len(valid_configs)} 組：拔除 {len(flags_to_pull)} 根，補齊 {len(flags_to_plant)} 根...")
                
