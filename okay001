                if unks:
                    def count_number_neighbors(r, c):
                        return sum(1 for dr in [-1,0,1] for dc in [-1,0,1] 
                                   if 0<=r+dr<5 and 0<=c+dc<5 and grid[r+dr][c+dc] in '012345') 
                    target = sorted(unks, key=lambda p: (count_number_neighbors(p[0], p[1]), p[0], p[1]))[0]
