# ⚙️ 狀態機控制層 (純視覺信任)
# ==========================================
def is_flag_on():
    # mss 監控區域設定
    monitor_flag = {"top": FLAG_BTN[1]-60, "left": FLAG_BTN[0]-60, "width": 120, "height": 120}
    
    # ✨ mss 直接產出 BGRA，利用 numpy 切片 [:, :, :3] 直接變 BGR，連 cvtColor 都省了！
    sct_img = sct.grab(monitor_flag)
    scr = np.array(sct_img)[:, :, :3] 
    
    res_on = cv2.matchTemplate(scr, TEMPLATES['FLAG_ON_BTN'][0], cv2.TM_CCOEFF_NORMED)
    res_off = cv2.matchTemplate(scr, TEMPLATES['FLAG_OFF_BTN'][0], cv2.TM_CCOEFF_NORMED)
    
    result = cv2.minMaxLoc(res_on)[1] > cv2.minMaxLoc(res_off)[1]
    del sct_img, scr # 幫垃圾車加速清理
    return result

def set_flag_mode(want_on):
    while is_flag_on() != want_on:
        print(f"🔄 視覺切換：{'開啟' if want_on else '關閉'}旗子模式")
        click_and_chill(FLAG_BTN, wait=2.0)

# ==========================================
# 🖱️ 手眼協調層：視覺極速驅動
# ==========================================
def click_and_watch(r, c, old_label):
    """✨ 終極視覺極速流：點擊後死盯著看，確認變成新圖案才等 0.2 秒放行！"""
    check_kill_switch()
    cx, cy = FIXED_CENTERS[r][c]
    
    # 計算 mss 需要的截圖範圍
    m_top = int(cy-20)
    m_left = int(cx-35)
    monitor_box = {"top": m_top, "left": m_left, "width": 70, "height": 40}
    
    pyautogui.click(cx, cy)
    pyautogui.moveTo(100, 100)
    
    start_t = time.time()
    while True:
        check_kill_switch()
        
        # ✨ mss 閃電截圖
        sct_img = sct.grab(monitor_box)
        scr = np.array(sct_img)[:, :, :3]
        max_conf, best_label = 0, old_label
        
        for label, tmpl_list in TEMPLATES.items():
            if label in ['REPLAY', 'FLAG_OFF_BTN', 'FLAG_ON_BTN']: continue
            for tmpl in tmpl_list:
                if scr.shape[0] < tmpl.shape[0] or scr.shape[1] < tmpl.shape[1]: continue
                val = cv2.minMaxLoc(cv2.matchTemplate(scr, tmpl, cv2.TM_CCOEFF_NORMED))[1]
                if val > max_conf: max_conf, best_label = val, label
            
        if max_conf >= (0.88 if best_label.isdigit() else (0.90 if best_label == 'Flag' else 0.85)):
            if best_label != old_label:
                time.sleep(0.2) 
                del sct_img, scr
                return True
                
        # 全域防護：結算畫面偵測
        if 'REPLAY' in TEMPLATES:
            sct_full = sct.grab(monitor_full)
            full_scr = np.array(sct_full)[:, :, :3]
            res_rep = cv2.matchTemplate(full_scr, TEMPLATES['REPLAY'][0], cv2.TM_CCOEFF_NORMED)
            if cv2.minMaxLoc(res_rep)[1] > 0.8:
                print("   🎉 周邊視覺捕捉到結算畫面！遊戲已瞬間結束！")
                del sct_img, scr, sct_full, full_scr
                return "ENDED"
                
        if time.time() - start_t > 5.0: 
            del sct_img, scr
            return False 
            
        # ✨ 強制垃圾回收與 CPU 讓步 (防爆核心)
        if 'full_scr' in locals(): del full_scr, sct_full
        del sct_img, scr
        time.sleep(0.01) # 給 CPU 一點喘息空間

def force_set_state(r, c, target_label, max_retries=3):
    old_label = '?' if target_label == 'Flag' else 'Flag'
    for attempt in range(max_retries):
        set_flag_mode(True) 
        res = click_and_watch(r, c, old_label)
        if res == "ENDED": return "ENDED"
        if res == True: return True
        print(f"   ⚠️ 第 {attempt+1} 次確認失敗，準備重試...")
    return False

def get_grid_state():
    check_kill_switch()
    try:
        sct_full = sct.grab(monitor_full)
        scr = np.array(sct_full)[:, :, :3]
    except: return "ERROR", None
    
    if 'REPLAY' in TEMPLATES:
        res_rep = cv2.matchTemplate(scr, TEMPLATES['REPLAY'][0], cv2.TM_CCOEFF_NORMED)
        if cv2.minMaxLoc(res_rep)[1] > 0.8:
            loc = cv2.minMaxLoc(res_rep)[3]
            del sct_full, scr
            return "REPLAY", (loc[0]+20, loc[1]+10)

    grid = [["?" for _ in range(5)] for _ in range(5)]
    for r in range(5):
        for c in range(5):
            cx, cy = FIXED_CENTERS[r][c]
            roi = scr[max(0, int(cy-20)):int(cy+20), max(0, int(cx-35)):int(cx+35)]
            if roi.size == 0: continue
            max_conf, best_label = 0, "?"
            
            for label, tmpl_list in TEMPLATES.items():
                if label in ['REPLAY', 'FLAG_OFF_BTN', 'FLAG_ON_BTN']: continue
                for tmpl in tmpl_list:
                    if roi.shape[0] < tmpl.shape[0] or roi.shape[1] < tmpl.shape[1]: continue
                    val = cv2.minMaxLoc(cv2.matchTemplate(roi, tmpl, cv2.TM_CCOEFF_NORMED))[1]
                    if val > max_conf: max_conf, best_label = val, label
                    
            if max_conf >= (0.88 if best_label.isdigit() else (0.90 if best_label == 'Flag' else 0.85)): 
                grid[r][c] = best_label
                
    del sct_full, scr
    return "GRID", grid

