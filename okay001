                        print(f"   🛑 網路超時或已結算！無法在 ({r},{c}) 拔除旗子。")
                        network_failed = True
                        break
                
                if hit_win or network_failed: break
                
                for r, c in flags_to_plant:
                    state_res = force_set_state(r, c, 'Flag') 
                    if state_res == "ENDED":
                        hit_win = True
                        break 
                    elif state_res == True:
                        currently_guessed_flags.add((r, c)) 
                    else:
                        print(f"   🛑 網路超時或已結算！無法在 ({r},{c}) 確認插旗。")
                        network_failed = True
                        break
                        
                if hit_win or network_failed: break
                    
